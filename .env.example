# Copy to .env and fill in. In production these are Railway variables.

# Injected automatically by Railway when linked to the Postgres plugin.
# For local runs: `railway run <cmd>` injects it, or paste the external URL here.
DATABASE_URL=postgresql://user:pass@host:5432/railway

# LLM enrichment tier (Phase 2+)
ANTHROPIC_API_KEY=

# Ingestion tuning
IMPORTANCE_THRESHOLD=0.6       # events below this skip LLM enrichment
GDELT_ENABLED=true
GDELT_MIN_IMPORTANCE=0.25      # GDELT events below this are not stored
GDELT_MAX_FILES_PER_RUN=12     # cap catch-up work per worker run (12 = 3 hours)
RSS_ENABLED=true

# Optional keys (Tier 3 sources, leave empty until used)
ACLED_KEY=
ACLED_EMAIL=
